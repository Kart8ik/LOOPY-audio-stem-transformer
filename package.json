{
  "name": "loopy-audio-stem-transformer",
  "version": "1.0.0",
  "description": "A monorepo for LOOPY - Audio Stem Transformer (Vocal Removal & Loop Sequencer)",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend",
    "frontend:preview": "npm run preview --workspace=frontend",
    "frontend:lint": "npm run lint --workspace=frontend",
    "backend:install": "cd backend && pip install -r requirements.txt",
    "backend:dev": "npm run dev --workspace=backend",
    "backend:start": "npm run start --workspace=backend",
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "build": "npm run frontend:build",
    "clean": "npm workspaces foreach --if-present run clean"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
